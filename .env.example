# Environment Configuration Example
# Copy this file to .env.local for development
# NEVER commit actual credentials to version control

# Environment
VITE_ENVIRONMENT=development

# API Configuration
VITE_API_URL=http://localhost:3001/api
VITE_SOCKET_URL=http://localhost:3001

# Payment Gateway Configuration (Development/Sandbox)
# M-Pesa (Daraja API) - Sandbox
VITE_MPESA_CONSUMER_KEY=your-sandbox-mpesa-consumer-key
VITE_MPESA_CONSUMER_SECRET=your-sandbox-mpesa-consumer-secret
VITE_MPESA_SHORTCODE=your-sandbox-mpesa-shortcode
VITE_MPESA_PASSKEY=your-sandbox-mpesa-passkey
VITE_MPESA_ENVIRONMENT=sandbox

# Airtel Money - Test
VITE_AIRTEL_CLIENT_ID=your-test-airtel-client-id
VITE_AIRTEL_CLIENT_SECRET=your-test-airtel-client-secret
VITE_AIRTEL_ENVIRONMENT=test

# Telkom Money - Test
VITE_TELKOM_API_KEY=your-test-telkom-api-key
VITE_TELKOM_MERCHANT_ID=your-test-telkom-merchant-id
VITE_TELKOM_ENVIRONMENT=test

# Card Payment Gateway (Test Keys)
VITE_STRIPE_PUBLIC_KEY=pk_test_your-stripe-test-public-key
VITE_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-your-flutterwave-test-public-key
VITE_PAYMENT_GATEWAY=stripe

# File Storage (Development)
VITE_FILE_STORAGE_URL=http://localhost:3001/uploads
VITE_FILE_STORAGE_REGION=us-east-1
VITE_FILE_STORAGE_BUCKET=nyumbasync-dev

# Cloudinary (Development)
VITE_CLOUDINARY_CLOUD_NAME=your-dev-cloudinary-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=nyumbasync-dev
VITE_CLOUDINARY_API_KEY=your-dev-cloudinary-api-key

# Monitoring and Error Tracking (Optional in Development)
# VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id
# VITE_SENTRY_ENVIRONMENT=development
# VITE_SENTRY_TRACES_SAMPLE_RATE=1.0

# Analytics (Optional in Development)
# VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
VITE_ENABLE_ANALYTICS=false

# Feature Flags
VITE_ENABLE_MOCK_DATA=true
VITE_ENABLE_DEBUG_MODE=true
VITE_ENABLE_PERFORMANCE_MONITORING=false

# WebSocket Configuration
VITE_SOCKET_RECONNECTION_ATTEMPTS=5
VITE_SOCKET_RECONNECTION_DELAY=3000
VITE_SOCKET_TIMEOUT=20000

# Security (Development)
VITE_ENABLE_HTTPS_ONLY=false
VITE_ENABLE_STRICT_CSP=false

# Rate Limiting
VITE_API_RATE_LIMIT=100
VITE_API_RATE_WINDOW=60000

# Cache Configuration
VITE_ENABLE_SERVICE_WORKER=false
VITE_CACHE_VERSION=1.0.0

# IMPORTANT NOTES:
# 1. Never commit .env files with real credentials
# 2. Use different credentials for development, staging, and production
# 3. Store production credentials securely (use environment variables in hosting platform)
# 4. Rotate credentials regularly
# 5. Use sandbox/test credentials for development
