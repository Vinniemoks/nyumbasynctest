# ============================================================
# NyumbaSync - Environment Variables Template
# Copy to: nyumbasync_backend/.env
# Never commit the real .env file
# ============================================================

NODE_ENV=production
PORT=3001

# ── Database ────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.spdjeub.mongodb.net/nyumbasync?retryWrites=true&w=majority

# ── Auth ────────────────────────────────────────────────────
JWT_SECRET=<generate: openssl rand -base64 64>
JWT_REFRESH_SECRET=<generate: openssl rand -base64 64>
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
SESSION_SECRET=<generate: openssl rand -base64 64>

# ── App URLs ────────────────────────────────────────────────
# Safaricom Cloud:
BASE_URL=https://api.nyumbasync.co.ke
FRONTEND_URL=https://app.nyumbasync.co.ke
CORS_ORIGINS=https://app.nyumbasync.co.ke,https://nyumbasync.co.ke

# ── M-Pesa (Safaricom Daraja) ───────────────────────────────
MPESA_CONSUMER_KEY=<from Daraja portal>
MPESA_CONSUMER_SECRET=<from Daraja portal>
MPESA_SHORTCODE=<your paybill or till number>
MPESA_PASSKEY=<from Daraja portal>
# Callback must be publicly accessible HTTPS URL:
# MPESA will POST payment results to this endpoint
MPESA_CALLBACK_URL=https://api.nyumbasync.co.ke/api/v1/mpesa-callback

# ── Email ────────────────────────────────────────────────────
# Option A: SendGrid (recommended)
SENDGRID_API_KEY=SG.<your-sendgrid-api-key>
SENDGRID_FROM_EMAIL=noreply@nyumbasync.co.ke

# Option B: SMTP / Gmail fallback (used if SENDGRID_API_KEY not set)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=<your-gmail>@gmail.com
EMAIL_PASSWORD=<gmail-app-password>
EMAIL_FROM=NyumbaSync <noreply@nyumbasync.co.ke>

# ── SMS (Twilio) ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC<your-account-sid>
TWILIO_AUTH_TOKEN=<your-auth-token>
TWILIO_PHONE_NUMBER=+<your-twilio-number>

# ── AWS S3 (backups / document storage) ─────────────────────
AWS_ACCESS_KEY_ID=<your-access-key>
AWS_SECRET_ACCESS_KEY=<your-secret-key>
AWS_REGION=af-south-1
AWS_S3_BUCKET=nyumbasync-backups-<your-account-id>

# ── Redis (optional, falls back to in-memory if not set) ─────
# REDIS_URL=redis://localhost:6379

# ── WebAuthn / Biometrics ────────────────────────────────────
RP_ID=app.nyumbasync.co.ke
RP_NAME=NyumbaSync
WEBAUTHN_ORIGIN=https://app.nyumbasync.co.ke
